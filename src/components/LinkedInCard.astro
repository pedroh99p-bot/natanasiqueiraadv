---
import Icon from './Icon.astro';

type Props = {
  href: string;
};

const { href } = Astro.props as Props;
---

<article class="linkedin-card" aria-labelledby="linkedin-card-title">
  <span class="linkedin-card__mark" aria-hidden="true">in</span>
  <div class="linkedin-card__content">
    <p class="linkedin-card__eyebrow">LinkedIn</p>
    <h3 id="linkedin-card-title">Natan Siqueira</h3>
    <p>Perfil profissional com atuação, pesquisa e publicações em Direito Criminal.</p>
    <a
      class="linkedin-card__action"
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      data-event="click_linkedin"
    >
      Ver perfil no LinkedIn
      <Icon name="external" class="icon icon--sm" />
    </a>
  </div>
</article>
